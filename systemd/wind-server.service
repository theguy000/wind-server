[Unit]
Description=wind-server auto-save daemon (watches Windsurf state.vscdb)
After=default.target

[Service]
Type=simple
ExecStart=%h/.local/bin/wind-server daemon
Restart=on-failure
RestartSec=5
# Don't bury the daemon if it crashes a few times in a row.
StartLimitIntervalSec=60
StartLimitBurst=10

[Install]
WantedBy=default.target
